{
  "properties": {
    "spec": {
      "additionalProperties": false,
      "properties": {
        "advertisements": {
          "additionalProperties": false,
          "properties": {
            "egress": {
              "additionalProperties": false,
              "properties": {},
              "type": "object"
            },
            "pod": {
              "additionalProperties": false,
              "properties": {},
              "type": "object"
            },
            "service": {
              "additionalProperties": false,
              "properties": {
                "ipTypes": {
                  "items": {
                    "enum": [
                      "ClusterIP",
                      "LoadBalancerIP",
                      "ExternalIP"
                    ],
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "bgpPeers": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "address": {
                "oneOf": [
                  {
                    "format": "ipv4"
                  },
                  {
                    "format": "ipv6"
                  }
                ],
                "type": "string"
              },
              "asn": {
                "format": "int32",
                "maximum": 65535,
                "minimum": 1,
                "type": "integer"
              },
              "gracefulRestartTimeSeconds": {
                "default": 120,
                "format": "int32",
                "maximum": 3600,
                "minimum": 1,
                "type": "integer"
              },
              "multihopTTL": {
                "default": 1,
                "format": "int32",
                "maximum": 255,
                "minimum": 1,
                "type": "integer"
              },
              "port": {
                "default": 179,
                "format": "int32",
                "maximum": 65535,
                "minimum": 1,
                "type": "integer"
              }
            },
            "required": [
              "address",
              "asn"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "confederation": {
          "additionalProperties": false,
          "properties": {
            "identifier": {
              "format": "int32",
              "maximum": 65535,
              "minimum": 1,
              "type": "integer"
            },
            "memberASNs": {
              "items": {
                "format": "int32",
                "maximum": 65535,
                "minimum": 1,
                "type": "integer"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "listenPort": {
          "default": 179,
          "format": "int32",
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        },
        "localASN": {
          "format": "int32",
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        },
        "nodeSelector": {
          "additionalProperties": false,
          "properties": {
            "matchExpressions": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "key": {
                    "type": "string"
                  },
                  "operator": {
                    "enum": [
                      "In",
                      "NotIn",
                      "Exists",
                      "DoesNotExist"
                    ],
                    "type": "string"
                  },
                  "values": {
                    "items": {
                      "pattern": "^(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])?$",
                      "type": "string"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "type": "array"
            },
            "matchLabels": {
              "x-kubernetes-preserve-unknown-fields": true
            }
          },
          "type": "object"
        }
      },
      "required": [
        "nodeSelector",
        "localASN"
      ],
      "type": "object"
    }
  },
  "required": [
    "spec"
  ],
  "type": "object",
  "x-flux-schema-type": "BGPPolicy"
}
